# --- Worker MyFrank (Agent SDK + plan Claude) ---

# Port d'écoute (Railway/Render l'injectent automatiquement)
PORT=3000

# Secret partagé qui protège l'endpoint /agents/followup/run.
# DOIT être identique à WORKER_SECRET côté Vercel.
WORKER_SECRET=

# Authentification du Claude Agent SDK avec TON PLAN (Pro/Max).
# À générer avec :  npx @anthropic-ai/claude-agent-sdk setup-token
# (ou `claude setup-token` si le CLI Claude Code est installé)
CLAUDE_CODE_OAUTH_TOKEN=

# Modèle utilisé pour la rédaction (optionnel)
AGENT_MODEL=claude-sonnet-5

# --- Connexion Odoo (mêmes valeurs que sur Vercel) ---
ODOO_URL=https://www.rank-nfc.fr
ODOO_DB=rank3
ODOO_USERNAME=elouan.vanderbeck@rank-nfc.fr
ODOO_API_KEY=
