# --- Connexion Odoo (CRM) ---
# À renseigner dans Vercel > Project Settings > Environment Variables
# (et NON dans le code). Ne jamais committer les vraies valeurs.
ODOO_URL=https://votre-instance-odoo.tld
ODOO_DB=nom_de_la_base
ODOO_USERNAME=utilisateur@exemple.com
ODOO_API_KEY=votre_cle_api_odoo

# --- Modèle de l'agent (conversation + rédaction des séquences) ---
# Clé API Anthropic. Requise pour le chat ET pour l'Agent 1 (génération
# des mails de relance). Sans elle, la connexion Odoo fonctionne mais
# la génération échoue.
ANTHROPIC_API_KEY=sk-ant-...

# --- Sécurité des crons (Agent 1 / Agent 2) ---
# Secret partagé qui protège les endpoints d'agents. Vercel l'envoie
# automatiquement en en-tête Authorization: Bearer <CRON_SECRET> lors des
# exécutions planifiées. Sert aussi de ?token=... pour les tests manuels.
CRON_SECRET=une_chaine_aleatoire_longue
