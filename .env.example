# --- Connexion Odoo (CRM) ---
# À renseigner dans Vercel > Project Settings > Environment Variables
# (et NON dans le code). Ne jamais committer les vraies valeurs.
ODOO_URL=https://votre-instance-odoo.tld
ODOO_DB=nom_de_la_base
ODOO_USERNAME=utilisateur@exemple.com
ODOO_API_KEY=votre_cle_api_odoo

# --- Worker (Agent 1 : rédaction des séquences via le plan Claude) ---
# La génération tourne sur un worker séparé (dossier worker/, déployé sur
# Railway/Render/Fly). Vercel ne fait que le déclencher.
WORKER_URL=https://votre-worker.exemple.app
WORKER_SECRET=le_meme_secret_que_sur_le_worker

# --- Sécurité des crons ---
# Secret partagé que Vercel envoie en Authorization: Bearer <CRON_SECRET>
# lors des exécutions planifiées, et utilisable en ?token=... en manuel.
CRON_SECRET=une_chaine_aleatoire_longue

# --- Clé API Anthropic (optionnelle) ---
# Utilisée UNIQUEMENT par le chat conversationnel de l'agent Odoo.
# L'Agent 1 (relances) n'en a PAS besoin : il passe par le worker + plan Claude.
ANTHROPIC_API_KEY=sk-ant-...
